# containerd registry configuration for Harbor (plain HTTP)
# This file is managed by Ansible — do not edit manually.
#
# Instructs containerd to reach this registry over plain HTTP without
# TLS verification. Suitable for local development only.

server = "http://{{ hostvars['localhost']['host_registry_host_ip'] }}:{{ harbor_port }}"

[host."http://{{ hostvars['localhost']['host_registry_host_ip'] }}:{{ harbor_port }}"]
  capabilities = ["pull", "resolve"]
  skip_verify = true
