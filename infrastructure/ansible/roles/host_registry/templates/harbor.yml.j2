# Harbor configuration file.
# Generated by Ansible — do not edit manually.

# The IP or hostname used by clients to reach Harbor.
# Set to the host bridge IP so Multipass VMs can pull images.
hostname: {{ host_registry_host_ip }}

# HTTP access (plain, no TLS — suitable for local development only)
http:
  port: {{ harbor_port }}

# HTTPS is disabled for local use.
# To enable HTTPS, uncomment the block below and provide valid certificate paths.
# https:
#   port: 443
#   certificate: /your/certificate/path
#   private_key: /your/private/key/path

# The initial password for the Harbor admin user.
# Change this after the first login.
harbor_admin_password: {{ harbor_admin_password }}

# Harbor DB configuration
database:
  password: root123
  max_idle_conns: 100
  max_open_conns: 900
  conn_max_lifetime: 5m
  conn_max_idle_time: 0

# Directory on the host where Harbor stores data (images, charts, logs).
data_volume: {{ harbor_data_dir }}

# Trivy — vulnerability scanner (disabled for local dev; uncomment to enable)
# trivy:
#   ignore_unfixed: false
#   skip_update: false
#   offline_scan: false
#   security_check: vuln
#   insecure: false

# Jobservice configuration
jobservice:
  max_job_workers: 10
  logger_sweeper_duration: 1
  job_loggers:
    - STD_OUTPUT
    - FILE

# Notification settings
notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3

# Log configuration
log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: /var/log/harbor

# Harbor release version — must match the installer version
_version: {{ harbor_version }}

# Proxy settings (leave empty if not behind a proxy)
proxy:
  http_proxy:
  https_proxy:
  no_proxy:
  components:
    - core
    - jobservice
    - trivy

# Automatic purging of uploaded artifacts
upload_purging:
  enabled: true
  age: 168h
  interval: 24h
  dryrun: false

# In-memory cache for metadata (disable for minimal footprint)
cache:
  enabled: false
  expire_hours: 24
