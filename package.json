{
  "name": "cloud-native-notification-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "docker-compose up --build",
    "dev:infra": "docker-compose up kafka schema-registry kafka-ui mailhog",
    "generate:types": "npm run generate --workspace=packages/schemas",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
